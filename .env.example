# ----------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values.
# ----------------------------------------------------------------------------

# LTA DataMall API key.
# Register for a free account at https://datamall.lta.gov.sg/ to get one.
# The Bus Arrival API requires this in the "AccountKey" request header.
# This is read ONLY on the server (API routes) and is never exposed to the browser.
LTA_ACCOUNT_KEY=

# When set to "1", the LTA client returns deterministic synthetic arrivals
# instead of calling the real API. Useful for local dev / demos when you
# don't have a key yet, or when the network can't reach DataMall.
# Leave unset/empty in production.
USE_MOCK_LTA=1

# ----------------------------------------------------------------------------
# Slack (stubbed for v1 — wire up later for "time to leave" notifications)
# ----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=
